# Sanity — from https://www.sanity.io/manage → Project → API
# This repo’s project URL path uses id 1fmk53vd (confirm in dashboard if unsure).
NEXT_PUBLIC_SANITY_PROJECT_ID=1fmk53vd
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-23

# Optional: for draft mode / Live Content API (https://www.sanity.io/docs/http-auth)
# SANITY_API_READ_TOKEN=

# Create/update Case study docs in Studio dataset (Editor token — keep secret)
# SANITY_API_WRITE_TOKEN=

# Optional — contact form (POST /api/contact). If unset, submissions still return OK (log in dev).
# RESEND_API_KEY=re_xxxx
# CONTACT_TO_EMAIL=hello@yourdomain.com
# CONTACT_FROM_EMAIL=Sandspire <onboarding@resend.dev>
# CONTACT_WEBHOOK_URL=https://hooks.zapier.com/...   (receives JSON: firstName, lastName, email, whatsapp, message, submittedAt)

# Sentry — from https://sentry.io/ after creating a Next.js project (Error Monitoring)
# DSN: Project → Client Keys. SDK does not init until NEXT_PUBLIC_SENTRY_DSN is set.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=   (optional; same DSN is fine for server/edge, or omit to reuse NEXT_PUBLIC_SENTRY_DSN in code)
# Cloudflare Worker (`@sentry/cloudflare` in `cf-worker-sentry.ts`): set in the Worker config in the dashboard
# or wrangler — SENTRY_DSN or NEXT_PUBLIC_SENTRY_DSN (never hardcode the DSN in source).
# Build-time source maps (add to Cloudflare/CI; local file optional — see Sentry skills doc):
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=   (project:releases + org:read; https://sentry.io/settings/auth-tokens/)
# .env.sentry-build-plugin  (gitignored) can hold SENTRY_AUTH_TOKEN for local releases upload only
